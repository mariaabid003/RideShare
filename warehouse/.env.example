# Copy this file to ".env" and fill in your Snowflake details.
# The loader (python-dotenv) and rundbt.ps1 both read warehouse/.env automatically.
# The real .env is gitignored — never commit it.

SNOWFLAKE_ACCOUNT=xy12345.eu-central-1   # your account locator/region
SNOWFLAKE_USER=YOUR_USER
SNOWFLAKE_PASSWORD=YOUR_PASSWORD
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=RIDESHARE_WH
SNOWFLAKE_DATABASE=RIDESHARE
